{
  "name": "file",
  "version": "1.0.0",
  "description": "檔案讀寫與目錄操作技能",
  "skills": [
    {
      "name": "read_file",
      "description": "讀取指定路徑的檔案內容",
      "parameters": {
        "path": {
          "type": "string",
          "description": "檔案路徑",
          "required": true
        }
      }
    },
    {
      "name": "write_file",
      "description": "將內容寫入指定路徑的檔案",
      "parameters": {
        "path": {
          "type": "string",
          "description": "檔案路徑",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "要寫入的內容",
          "required": true
        }
      }
    },
    {
      "name": "list_directory",
      "description": "列出指定目錄下的檔案與子目錄",
      "parameters": {
        "path": {
          "type": "string",
          "description": "目錄路徑，預設為當前目錄",
          "required": false
        }
      }
    }
  ]
}
